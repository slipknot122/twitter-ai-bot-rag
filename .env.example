TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_SESSION_STRING=your_session_string_here

# Список каналів для моніторингу.
TELEGRAM_CHANNELS='["https://t.me/Flipperbodenhon"]'

TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_SECRET=your_twitter_api_secret_here
TWITTER_ACCESS_TOKEN=your_twitter_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret_here
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# --- Media Generation ---
MEDIA_GENERATION_ENABLED=true
MEDIA_PROVIDER_ORDER=cloudflare,pollinations

# Cloudflare Workers AI
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_IMAGE_MODEL=@cf/black-forest-labs/flux-1-schnell

# Pollinations (fallback)
POLLINATIONS_API_KEY=
POLLINATIONS_IMAGE_MODEL=flux

# Image settings
MEDIA_IMAGE_WIDTH=1200
MEDIA_IMAGE_HEIGHT=675
MEDIA_GENERATION_TIMEOUT=60
MEDIA_MAX_BYTES=10000000
